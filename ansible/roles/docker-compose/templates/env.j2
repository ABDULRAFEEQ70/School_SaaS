---
# Environment variables for School SaaS application
DATABASE_URL=postgresql://{{ database.user }}:{{ database.password }}@{{ database.host }}:{{ database.port }}/{{ database.name }}
REDIS_URL=redis://:{{ redis.password }}@{{ redis.host }}:{{ redis.port }}/0
APP_PORT={{ app_port }}
APP_ENV={{ environment }}
LOG_LEVEL={{ log_level }}

# Docker settings
DOCKER_IMAGE_TAG={{ docker_image_tag }}

# Monitoring settings
CLOUDWATCH_NAMESPACE={{ monitoring.cloudwatch_namespace }}
