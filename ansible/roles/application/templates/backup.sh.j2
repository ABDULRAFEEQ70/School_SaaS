#!/bin/bash

set -e

APP_NAME="{{ app_name }}"
BACKUP_DIR="/var/backups/${APP_NAME}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
RETENTION_DAYS={{ backup.retention_days }}

echo "Starting backup for ${APP_NAME} at ${TIMESTAMP}"

mkdir -p "${BACKUP_DIR}"

# Backup PostgreSQL database
echo "Backing up PostgreSQL database..."
docker exec ${APP_NAME}-postgres pg_dump -U {{ database.user }} {{ database.name }} | gzip > "${BACKUP_DIR}/db_${TIMESTAMP}.sql.gz"

# Backup Redis data
echo "Backing up Redis data..."
docker exec ${APP_NAME}-redis redis-cli -a {{ redis.password }} --rdb /data/dump.rdb
docker cp ${APP_NAME}-redis:/data/dump.rdb "${BACKUP_DIR}/redis_${TIMESTAMP}.rdb"
gzip "${BACKUP_DIR}/redis_${TIMESTAMP}.rdb"

# Cleanup old backups
echo "Cleaning up old backups older than ${RETENTION_DAYS} days..."
find "${BACKUP_DIR}" -name "*.sql.gz" -mtime +${RETENTION_DAYS} -delete
find "${BACKUP_DIR}" -name "*.rdb.gz" -mtime +${RETENTION_DAYS} -delete

# Backup Docker Compose configuration
echo "Backing up Docker Compose configuration..."
tar -czf "${BACKUP_DIR}/compose_${TIMESTAMP}.tar.gz" -C /opt/${APP_NAME} docker-compose/

# Calculate backup size
BACKUP_SIZE=$(du -sh "${BACKUP_DIR}" | cut -f1)

echo "Backup completed successfully"
echo "Total backup size: ${BACKUP_SIZE}"
echo "Backup location: ${BACKUP_DIR}"

